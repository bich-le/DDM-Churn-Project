# Data should be downloaded/prepared locally following Data/README.md.
Data/Raw/
Data/Processed/
Data/Intermediate/

# Keep empty folder structure if needed
!Data/.gitkeep
!Data/Raw/.gitkeep
!Data/Processed/.gitkeep
!Data/Intermediate/.gitkeep
!Data/Intermediate/features/.gitkeep
!Data/Intermediate/analysis/.gitkeep
!Data/Intermediate/market_basket/.gitkeep


