# ============================================================
# DATA FILES
# ============================================================

# Raw data is usually large and should not be committed
Data/Raw/

# Optional: ignore heavy CSV files in data folders
# Uncomment only if the team does not want CSV data tracked
# Data/**/*.csv

# Keep parquet files in Dunnhumby folder if needed
!Data/Dunnhumby/*.parquet


# ============================================================
# PYTHON CACHE / BUILD ARTIFACTS
# ============================================================

__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Jupyter
.ipynb_checkpoints/
.jupyter_runtime/


# ============================================================
# VIRTUAL ENVIRONMENTS
# ============================================================

.venv/
venv/
env/
.virtualenvs/


# ============================================================
# OS / IDE / LOCAL FILES
# ============================================================

.DS_Store
Thumbs.db

.vscode/
.idea/

*.log


# ============================================================
# ACCIDENTAL LOCAL PACKAGE SHADOWING
# ============================================================

# Do not commit a local folder named imblearn.
# The real package should come from imbalanced-learn in requirements.txt
imblearn/


